# Data access mode: memory-demo (default) or supabase
NEXT_PUBLIC_DATA_ACCESS_MODE=memory-demo

# Browser-safe Supabase configuration. Use only an anonymous/publishable key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anonymous-key

# Optional server-only configuration. Never prefix secrets with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anonymous-key
